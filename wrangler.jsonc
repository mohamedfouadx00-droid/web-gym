{
  "name": "web-gym",
  "main": "worker.ts",
  "compatibility_date": "2026-07-07",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/*"
    ]
  },
  "ai": {
    "binding": "AI"
  },
  "vars": {
    "AI_TEXT_MODEL": "@cf/zai-org/glm-4.7-flash",
    "AI_STRUCTURED_MODEL": "@cf/meta/llama-3.3-70b-instruct-fp8-fast"
  }
}
